{
  "family": "engagecart-backend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "executionRoleArn": "arn:aws:iam::819548484835:role/LabRole",
  "taskRoleArn": "arn:aws:iam::819548484835:role/LabRole",
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "engagecart-backend-container",
      "image": "REPLACE_ME_IN_GITHUB_ACTIONS",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "hostPort": 5000,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/engagecart-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
